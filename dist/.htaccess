# ============================================================
# S&R Consultoria — .htaccess para HostGator (Apache + PHP 8)
# ============================================================
# Inclui: HTTPS forçado, redirect non-www, gzip, cache, headers
# de segurança, página 404 customizada e bloqueio de listagem.
# ============================================================

# Ativa o motor de reescrita
RewriteEngine On
Options -Indexes -MultiViews
ServerSignature Off

# ------------------------------------------------------------
# 1. HTTPS obrigatório (301)
# ------------------------------------------------------------
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ------------------------------------------------------------
# 2. Sem www (301) — canônico em srgestaotributaria.com
#    Se preferir COM www, comente este bloco.
# ------------------------------------------------------------
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ------------------------------------------------------------
# 3. Página 404 amigável
# ------------------------------------------------------------
ErrorDocument 404 /404.html

# ------------------------------------------------------------
# 4. Bloqueia arquivos sensíveis
# ------------------------------------------------------------
<FilesMatch "(^\.|\.(md|log|sh|ps1|py|bak|sql|env|gitignore)$)">
    Require all denied
</FilesMatch>

# ------------------------------------------------------------
# 5. Headers de segurança (Content-Security-Policy permissiva
#    o bastante para Google Fonts, Unsplash e Instagram embed)
# ------------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # CSP — permite recursos legítimos do site
    Header always set Content-Security-Policy "default-src 'self'; \
        script-src 'self' 'unsafe-inline' https://www.instagram.com https://*.instagram.com https://platform.instagram.com; \
        style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://www.instagram.com https://*.cdninstagram.com; \
        img-src 'self' data: blob: https:; \
        font-src 'self' https://fonts.gstatic.com data:; \
        connect-src 'self' https:; \
        frame-src https://www.instagram.com https://*.instagram.com; \
        base-uri 'self'; \
        form-action 'self' https:; \
        frame-ancestors 'self';"
</IfModule>

# ------------------------------------------------------------
# 6. Compressão Gzip / Deflate
# ------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/manifest+json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# Brotli quando disponível (HostGator suporta em alguns planos)
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/javascript
    AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json
    AddOutputFilterByType BROTLI_COMPRESS image/svg+xml
</IfModule>

# ------------------------------------------------------------
# 7. Cache de assets estáticos (1 ano para versionados, curtinho para HTML)
# ------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                          "access plus 1 month"

    # HTML — curto, para refletir mudanças rápido
    ExpiresByType text/html                 "access plus 0 seconds"
    ExpiresByType application/xhtml+xml     "access plus 0 seconds"

    # Sitemap / robots — curto
    ExpiresByType application/xml           "access plus 1 hour"
    ExpiresByType text/xml                  "access plus 1 hour"
    ExpiresByType text/plain                "access plus 1 hour"

    # Manifest e JSON
    ExpiresByType application/manifest+json "access plus 1 week"
    ExpiresByType application/json          "access plus 0 seconds"

    # CSS / JS — 1 mês (mudar versionamento ao subir nova versão)
    ExpiresByType text/css                  "access plus 1 month"
    ExpiresByType application/javascript    "access plus 1 month"
    ExpiresByType text/javascript           "access plus 1 month"

    # Imagens e fontes — 1 ano (imutáveis)
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/avif                "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/gif                 "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/x-icon              "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType application/font-woff2    "access plus 1 year"
</IfModule>

# Cache-Control granular (complementa mod_expires)
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|svg|jpg|jpeg|png|webp|avif|woff2|woff)$">
        Header set Cache-Control "public, max-age=2592000, stale-while-revalidate=86400"
    </FilesMatch>
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=300, must-revalidate"
    </FilesMatch>
    <FilesMatch "\.(xml|txt)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
</IfModule>

# ------------------------------------------------------------
# 8. MIME types extras
# ------------------------------------------------------------
<IfModule mod_mime.c>
    AddType image/webp                      .webp
    AddType image/avif                      .avif
    AddType font/woff2                      .woff2
    AddType application/manifest+json       .webmanifest
    AddType image/svg+xml                   .svg .svgz
</IfModule>

# ------------------------------------------------------------
# 9. Charset padrão
# ------------------------------------------------------------
AddDefaultCharset UTF-8

# ------------------------------------------------------------
# 10. DirectoryIndex
# ------------------------------------------------------------
DirectoryIndex index.html
