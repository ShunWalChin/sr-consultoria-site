# ============================================================
# .gitignore — Repositório sr-consultoria-site
# ============================================================

# ---------- Sistema / IDE ----------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-*

# ---------- Ferramentas locais de IA ----------
.claude/
.codex/

# ---------- Legados (mantidos localmente, fora do git) ----------
public_html/
elevenlabs/
sr-consultoria-deploy/
dev-server.mjs
site_final.zip
DESIGN.md

# ---------- Artefatos de build (gerados a cada release) ----------
*.zip
!dist/**/*.zip

# ---------- Credenciais e configs sensíveis ----------
.env
.env.*
config.local.*
secrets.*
*.pem
*.key

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*

# ---------- Node (caso adicione build futuramente) ----------
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ---------- Python (scripts de utilitário) ----------
__pycache__/
*.py[cod]
*.egg-info/

# ---------- HostGator backups ----------
*.bak
*.tar.gz

# ---------- Imagens originais grandes (mantidas no Drive) ----------
# Descomente se as fotos da equipe forem grandes:
# sr-consultoria/assets/img/*.psd
# sr-consultoria/assets/img/_originals/
