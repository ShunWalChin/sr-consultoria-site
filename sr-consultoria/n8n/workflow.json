      "parameters": {
        "jsCode": "// ============================================================\n// VALIDAÇÃO + SANITIZAÇÃO do payload do formulário\n// ============================================================\nconst body = $input.first().json.body || $input.first().json || {};\n\n// Honeypot — bots costumam preencher qualquer field\nif (body._site) {\n  return [{ json: { _honeypot: true, ok: true, message: 'Recebido.' } }];\n}\n\n// Helper de sanitização\nconst clean = (v, max = 200) => {\n  if (v == null) return '';\n  return String(v).trim().replace(/[\\r\\n\\t]+/g, ' ').slice(0, max);\n};\n\nconst lead = {\n  nome:          clean(body.nome, 120),\n  whatsapp:      clean(body.whatsapp, 30),\n  email:         clean(body.email, 120).toLowerCase(),\n  empresa:       clean(body.empresa, 120),\n  cidade:        clean(body.cidade, 80),\n  tempo:         clean(body.tempo, 60),\n  atividade:     clean(body.atividade, 120),\n  faturamento:   clean(body.faturamento, 60),\n  perfilCliente: clean(body.perfilCliente, 120),\n  duvida:        clean(body.duvida, 200),\n  prazo:         clean(body.prazo, 80),\n  lgpd:          !!body.lgpd,\n  origem:        clean(body._origem || 'Diagnóstico Reforma Tributária', 80),\n  timestamp:     new Date().toISOString(),\n  ip:            $input.first().json.headers?.['x-forwarded-for']?.split(',')[0]?.trim()\n                || $input.first().json.headers?.['x-real-ip']\n                || 'desconhecido',\n};\n\n// Validação\nconst errors = [];\nif (lead.nome.length < 3)                                errors.push('Nome inválido.');\nif (!/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(lead.email))     errors.push('E-mail inválido.');\nif (!lead.whatsapp)                                      errors.push('WhatsApp obrigatório.');\nif (!lead.cidade)                                        errors.push('Cidade obrigatória.');\nif (!lead.atividade)                                     errors.push('Atividade obrigatória.');\nif (!lead.faturamento)                                   errors.push('Faturamento obrigatório.');\nif (!lead.perfilCliente)                                 errors.push('Perfil de cliente obrigatório.');\nif (!lead.duvida)                                        errors.push('Dúvida obrigatória.');\nif (!lead.lgpd)                                          errors.push('Autorização LGPD obrigatória.');\n\nif (errors.length) {\n  return [{ json: { _invalid: true, ok: false, message: errors.join(' '), status: 422 } }];\n}\n\n// Normaliza WhatsApp para wa.me (só dígitos + prefixo 55)\nlet waDigits = lead.whatsapp.replace(/\\D/g, '');\nif (waDigits && !waDigits.startsWith('55')) waDigits = '55' + waDigits;\nlead.waDigits = waDigits;\nlead.waLink   = `https://wa.me/${waDigits}`;\n\n// Pronto para os próximos nodes\nreturn [{ json: lead }];"
      },
