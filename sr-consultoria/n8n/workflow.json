    {
      "parameters": {
        "sendTo": "srgestaotributaria@gmail.com",
        "subject": "=🔔 Novo lead — Diagnóstico Reforma Tributária: {{ $json.nome }}",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html lang=\"pt-BR\"><head><meta charset=\"utf-8\"></head>\n<body style=\"margin:0;padding:24px;background:#F7F7F7;font-family:'Segoe UI',Arial,sans-serif;color:#252525\">\n  <div style=\"max-width:640px;margin:0 auto;background:#fff;border:1px solid #E5E5E5;border-radius:14px;overflow:hidden;box-shadow:0 4px 20px rgba(11,32,71,.06)\">\n    <div style=\"background:linear-gradient(135deg,#0B2047 0%,#152848 100%);color:#fff;padding:28px 32px\">\n      <div style=\"font-family:Georgia,serif;font-size:13px;color:#DBBD85;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:8px\">Diagnóstico Reforma Tributária</div>\n      <h1 style=\"margin:0;font-family:Georgia,serif;font-size:22px;font-weight:400;line-height:1.25\">Novo lead recebido</h1>\n      <p style=\"margin:8px 0 0;color:rgba(255,255,255,.75);font-size:13px\">Resposta esperada em até 1 dia útil &middot; LGPD autorizado</p>\n    </div>\n    <table style=\"width:100%;border-collapse:collapse;font-size:14px\">\n      <tr><td style=\"padding:10px 14px;background:#FAF9F5;border-bottom:1px solid #E5E5E5;font-weight:600;color:#0B2047;width:32%\">Nome</td><td style=\"padding:10px 14px;background:#fff;border-bottom:1px solid #E5E5E5\">{{ $json.nome }}</td></tr>\n      <tr><td style=\"padding:10px 14px;background:#FAF9F5;border-bottom:1px solid #E5E5E5;font-weight:600;color:#0B2047\">WhatsApp</td><td style=\"padding:10px 14px;background:#fff;border-bottom:1px solid #E5E5E5\"><a href=\"{{ $json.waLink }}\" style=\"color:#25D366;font-weight:600;text-decoration:none\">{{ $json.whatsapp }}</a> &nbsp;·&nbsp; <a href=\"{{ $json.waLink }}\" style=\"color:#0B2047;font-size:12px\">Responder no WhatsApp →</a></td></tr>\n      <tr><td style=\"padding:10px 14px;background:#FAF9F5;border-bottom:1px solid #E5E5E5;font-weight:600;color:#0B2047\">E-mail</td><td style=\"padding:10px 14px;background:#fff;border-bottom:1px solid #E5E5E5\"><a href=\"mailto:{{ $json.email }}\" style=\"color:#0B2047\">{{ $json.email }}</a></td></tr>\n      <tr><td style=\"padding:10px 14px;background:#FAF9F5;border-bottom:1px solid #E5E5E5;font-weight:600;color:#0B2047\">Empresa</td><td style=\"padding:10px 14px;background:#fff;border-bottom:1px solid #E5E5E5\">{{ $json.empresa || '—' }}</td></tr>\n      <tr><td style=\"padding:10px 14px;background:#FAF9F5;border-bottom:1px solid #E5E5E5;font-weight:600;color:#0B2047\">Cidade / UF</td><td style=\"padding:10px 14px;background:#fff;border-bottom:1px solid #E5E5E5\">{{ $json.cidade }}</td></tr>\n      <tr><td style=\"padding:10px 14px;background:#FAF9F5;border-bottom:1px solid #E5E5E5;font-weight:600;color:#0B2047\">Tempo de empresa</td><td style=\"padding:10px 14px;background:#fff;border-bottom:1px solid #E5E5E5\">{{ $json.tempo || '—' }}</td></tr>\n      <tr><td style=\"padding:10px 14px;background:#FAF9F5;border-bottom:1px solid #E5E5E5;font-weight:600;color:#0B2047\">Atividade</td><td style=\"padding:10px 14px;background:#fff;border-bottom:1px solid #E5E5E5\">{{ $json.atividade }}</td></tr>\n      <tr><td style=\"padding:10px 14px;background:#FAF9F5;border-bottom:1px solid #E5E5E5;font-weight:600;color:#0B2047\">Faturamento</td><td style=\"padding:10px 14px;background:#fff;border-bottom:1px solid #E5E5E5\">{{ $json.faturamento }}</td></tr>\n      <tr><td style=\"padding:10px 14px;background:#FAF9F5;border-bottom:1px solid #E5E5E5;font-weight:600;color:#0B2047\">Perfil de cliente</td><td style=\"padding:10px 14px;background:#fff;border-bottom:1px solid #E5E5E5\">{{ $json.perfilCliente }}</td></tr>\n      <tr><td style=\"padding:10px 14px;background:#FAF9F5;border-bottom:1px solid #E5E5E5;font-weight:600;color:#0B2047\">Maior dúvida</td><td style=\"padding:10px 14px;background:#fff;border-bottom:1px solid #E5E5E5\">{{ $json.duvida }}</td></tr>\n      <tr><td style=\"padding:10px 14px;background:#FAF9F5;border-bottom:1px solid #E5E5E5;font-weight:600;color:#0B2047\">Prazo</td><td style=\"padding:10px 14px;background:#fff;border-bottom:1px solid #E5E5E5\">{{ $json.prazo || '—' }}</td></tr>\n      <tr><td style=\"padding:10px 14px;background:#FAF9F5;border-bottom:1px solid #E5E5E5;font-weight:600;color:#0B2047\">Recebido em</td><td style=\"padding:10px 14px;background:#fff;border-bottom:1px solid #E5E5E5\">{{ $json.timestamp }}</td></tr>\n    </table>\n    <div style=\"padding:20px 32px;background:#FAF9F5;border-top:1px solid #E5E5E5;text-align:center\">\n      <a href=\"{{ $json.waLink }}\" style=\"display:inline-block;background:#25D366;color:#fff;padding:12px 24px;border-radius:8px;text-decoration:none;font-weight:600;font-size:14px\">Responder no WhatsApp</a> &nbsp;\n      <a href=\"mailto:{{ $json.email }}\" style=\"display:inline-block;background:#0B2047;color:#fff;padding:12px 24px;border-radius:8px;text-decoration:none;font-weight:600;font-size:14px\">Responder por e-mail</a>\n    </div>\n    <div style=\"padding:16px 32px;text-align:center;font-size:11px;color:#8a8a8a\">Notificação automática &middot; via n8n</div>\n  </div>\n</body></html>",
        "options": {
          "replyTo": "={{ $json.nome }} <{{ $json.email }}>"
        }
